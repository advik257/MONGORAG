# OpenAI API Configuration
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: OpenAI Model Configuration
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Database Configuration (Optional - for Notebook 4: PostgreSQL)
# Only needed if you're running the PostgreSQL notebook

# Option 1: Local PostgreSQL
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=your_username
# POSTGRES_PASSWORD=your_password
# POSTGRES_DB=your_database_name

# Text Chunking Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Storage Backend Configuration
STORAGE_BACKEND=local  # Options: local, s3

# S3 Configuration (for Lambda deployment)
S3_CACHE_BUCKET=my-rag-cache-bucket
AWS_REGION=us-east-1

# AWS Credentials (optional - use IAM role in Lambda)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key


# Application Settings

APP_NAME=Multi-Source RAG + Text-to-SQL
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=False
LOG_LEVEL=INFO


